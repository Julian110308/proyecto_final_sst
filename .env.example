# ============================================================
# VARIABLES DE ENTORNO — SST Centro Minero
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el .env real al repositorio
# ============================================================

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Base de datos ────────────────────────────────────────────
# Desarrollo (SQLite)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Produccion / Docker (PostgreSQL) — descomentar y completar:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sst_db
# DB_USER=sst_user
# DB_PASSWORD=cambiar_por_password_seguro
# DB_HOST=db
# DB_PORT=5432

# ── Redis (Celery + Django Channels) ────────────────────────
# Desarrollo local: redis://localhost:6379/0
# Docker:          redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Email (Recuperacion de contrasena) ──────────────────────
# Dejar vacio para usar backend de consola en desarrollo
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Solo necesarios si EMAIL_HOST_USER esta configurado:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=SST Centro Minero <noreply@centrominerosst.com>

# ── Web Push (Notificaciones VAPID) ─────────────────────────
# Generar con: python manage.py generate_vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@centrominerosena.edu.co

# ── Sentry (Monitoreo de errores — Fase 5) ──────────────────
# Obtener DSN en https://sentry.io despues de crear el proyecto
SENTRY_DSN=

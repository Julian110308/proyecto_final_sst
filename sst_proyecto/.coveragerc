[run]
source = .
omit =
    */migrations/*
    */management/*
    manage.py
    */asgi.py
    */wsgi.py
    */tests.py
    */tests/*
    crear_usuarios.py
    fix_coordenadas.py
    poblar_db.py
    reportes/csv_generator.py
    reportes/excel_generator.py
    reportes/pdf_generator.py
    reportes/tasks.py
    usuarios/utils.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    if settings.DEBUG
    raise NotImplementedError
    pass
